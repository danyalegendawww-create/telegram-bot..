@router.callback_query(F.data == "buy_unban")
async def buy_unban(callback: CallbackQuery, bot: Bot, state: FSMContext):
    """Покупка разбана"""
    user_id = callback.from_user.id
    username = callback.from_user.username or ""
    
    # Генерируем payload
    import uuid
    payload = str(uuid.uuid4())
    
    # Создаем заказ в БД
    order_id = await db.create_order(
        user_id=user_id,
        username=username,
        purchase_type="unban",
        price=UNBAN_PRICE,
        payload=payload,
        product_name=None
    )
    
    # Сохраняем данные в FSM
    await state.update_data(
        order_id=order_id,
        purchase_type="unban",
        item_type=PURCHASE_TYPES["unban"],
        price=UNBAN_PRICE,
        payload=payload
    )
    
    # Отправляем счет
    try:
        await send_invoice(
            bot=bot,
            chat_id=user_id,
            title="🔓 Разбан на сервере",
            description="Разбан аккаунта на Minecraft сервере",
            price=UNBAN_PRICE,
            payload=payload
        )
        await callback.answer()
    except Exception as e:
        logging.error(f"Ошибка при создании счета: {e}")
        await callback.answer("❌ Произошла ошибка при создании счета", show_alert=True)


@router.callback_query(F.data.startswith("priv_"))
async def buy_privilege(callback: CallbackQuery, bot: Bot, state: FSMContext):
    """Покупка привилегии"""
    privilege_name = callback.data.split("_")[1]
    price = PRIVILEGES.get(privilege_name)
    
    if not price:
        await callback.answer("❌ Привилегия не найдена", show_alert=True)
        return
    
    user_id = callback.from_user.id
    username = callback.from_user.username or ""
    
    # Генерируем payload
    import uuid
    payload = str(uuid.uuid4())
    
    # Создаем заказ в БД
    order_id = await db.create_order(
        user_id=user_id,
        username=username,
        purchase_type="privilege",
        price=price,
        payload=payload,
        product_name=privilege_name
    )
    
    # Сохраняем данные в FSM
    await state.update_data(
        order_id=order_id,
        purchase_type="privilege",
        privilege_name=privilege_name,
        item_type=f"{PURCHASE_TYPES['privilege']}: {privilege_name}",
