@router.message(F.successful_payment)
async def handle_successful_payment(message: Message, bot: Bot, state: FSMContext):
    """Обработка успешного платежа"""
    # Обрабатываем платеж с проверками
    payment_data = await process_successful_payment(message)
    
    if not payment_data:
        await message.answer("❌ Ошибка при обработке платежа. Пожалуйста, свяжитесь с администратором.")
        return
    
    payload = payment_data["payload"]
    payment_id = payment_data["payment_id"]
    price = payment_data["price"]
    
    # Проверяем, не обработан ли уже этот платеж
    existing_order = await db.get_order_by_payment_id(payment_id)
    if existing_order:
        logging.warning(f"⚠️ Платеж уже обработан: {payment_id}")
        await message.answer(
            "✅ Этот платеж уже был обработан.\n"
            "Если у вас есть вопросы, обратитесь к администратору."
        )
        return
    
    # Получаем заказ по payload
    order = await db.get_order_by_payload(payload)
    if not order:
        logging.warning(f"⚠️ Заказ не найден для payload: {payload}")
        await message.answer(
            "❌ Заказ не найден. Пожалуйста, свяжитесь с администратором."
        )
        return
    
    # Проверяем сумму
    expected_price = order["price"]
    if price != expected_price:
        logging.warning(f"⚠️ Несоответствие суммы: ожидалось {expected_price}, получено {price}")
        # Все равно обрабатываем, но логируем
        await message.answer(
            "⚠️ Сумма платежа не соответствует ожидаемой.\n"
            "Обратитесь к администратору для уточнения."
        )
    
    # Обновляем заказ в БД
    await db.update_order_payment(order["order_id"], payment_id)
    
    # Получаем данные из FSM
    user_data = await state.get_data()
    item_type = user_data.get("item_type", order["purchase_type"])
    
    # Обновляем данные в FSM
    await state.update_data(
        payment_id=payment_id,
        price=price,
        timestamp=get_moscow_time()
    )
    
    # Запрашиваем ник
    await state.set_state(PurchaseStates.waiting_for_nickname)
    await message.answer(
        "✅ Оплата прошла успешно!\n\n"
        "✏️ Теперь введи свой **ник в Minecraft**, чтобы мы могли выдать тебе покупку.\n"
        "Просто напиши его в чат.",
        reply_markup=get_cancel_keyboard()
    )


@router.message(StateFilter(PurchaseStates.waiting_for_nickname), F.text)
async def handle_nickname(message: Message, bot: Bot, state: FSMContext):
    """Обработка ввода ника Minecraft"""
    user_id = message.from_user.id
    nickname = message.text.strip()
    
    # Валидация ника
    if not validate_minecraft_nickname(nickname):
        await message.answer(
            "❌ Неверный формат ника!\n"
            "Ник должен содержать от 2 до 16 символов (буквы, цифры, подчеркивание).\n"
            "Попробуйте еще раз:",
            reply_markup=get_cancel_keyboard()
        )
        return
    
    # Получаем данные из FSM
    user_data = await state.get_data()
    
    if not user_data or "order_id" not in user_data:
        await message.answer("❌ Данные о покупке не найдены. Начните заново с /start")
        await state.clear()
        return
    
    order_id = user_data["order_id"]
    item_type = user_data.get("item_type", "Неизвестно")
    price = user_data.get("price", 0)
    time_str = user_data.get("timestamp", get_moscow_time())
    payment_id = user_data.get("payment_id", "Неизвестно")
    
    # Обновляем заказ в БД
    await db.update_order_nickname(order_id, nickname)
    
    # Отправляем уведомление администраторам
    admin_message = format_admin_message(
        username=message.from_user.username or "",
        user_id=user_id,
        nickname=nickname,
        purchase_type=item_type,
        price=price,
        time_str=time_str,
        payment_id=payment_id,
        order_id=order_id
    )
    
    # Отправляем всем администраторам
    success_count = 0
    for admin_id in ADMIN_IDS:
        try:
            await bot.send_message(admin_id, admin_message, parse_mode="HTML")
            success_count += 1
        except Exception as e:
            logging.error(f"❌ Не удалось отправить сообщение админу {admin_id}: {e}")
    
    if success_count == 0:
        logging.error("❌ Не удалось отправить уведомление ни одному администратору")
        await message.answer(
            "⚠️ Произошла ошибка при отправке уведомления администраторам.\n"
            "Пожалуйста, свяжитесь с администратором вручную."
        )
    else:
        # Подтверждаем пользователю
        await message.answer(
            "✅ Отлично! Твой заказ отправлен администраторам.\n"
            "Ожидай выдачи в ближайшее время. ⏳\n\n"
            f"🆔 Номер заказа: {order_id}"
        )
    
    # Очищаем состояние
    await state.clear()


