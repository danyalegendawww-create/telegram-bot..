            chat_id=user_id,
            title=f"🛡 Привилегия {privilege_name}",
            description=f"Покупка привилегии {privilege_name} на Minecraft сервере",
            price=price,
            payload=payload
        )
        await callback.answer()
    except Exception as e:
        logging.error(f"Ошибка при создании счета: {e}")
        await callback.answer("❌ Произошла ошибка при создании счета", show_alert=True)


